APP_ENV=local
APP_PORT=8000

OPENEO_BASE_URL=https://openeo.dataspace.copernicus.eu
OPENEO_CLIENT_ID=replace-me
OPENEO_CLIENT_SECRET=replace-me
# Token OIDC de usuario para endpoints de procesamiento (/result, /jobs).
# Opcional si usas OPENEO_REFRESH_TOKEN.
OPENEO_ACCESS_TOKEN=replace-with-user-oidc-token
# Recomendado para renovacion automatica del access token de procesamiento.
OPENEO_REFRESH_TOKEN=replace-with-user-refresh-token
# Opcional: por defecto usa OPENEO_CLIENT_ID para el flujo refresh_token.
OPENEO_REFRESH_CLIENT_ID=
# Opcional: solo si tu cliente refresh_token es confidencial.
OPENEO_REFRESH_CLIENT_SECRET=
SIMFAT_BACKEND_URL=http://localhost:8080
SIMFAT_BACKEND_INDICATOR_INGEST_PATH=/api/indicators/measurements
SIMFAT_BACKEND_TIMEOUT_SECONDS=10
# Optional: solo si backend exige auth bearer.
SIMFAT_BACKEND_AUTH_TOKEN=
# true: publica al backend; false: permite validar openEO en forma aislada.
SIMFAT_BACKEND_SYNC_ENABLED=true
